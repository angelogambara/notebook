CREATE TABLE IF NOT EXISTS __item__ (
  id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(95) NOT NULL
);

CREATE TABLE IF NOT EXISTS __list__ (
  id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  id_item INT UNSIGNED NOT NULL,
  name VARCHAR(95) NOT NULL,
  description VARCHAR(1024),

  CONSTRAINT fk___list___id_item
  FOREIGN KEY (id_item)
    REFERENCES __item__ (id)
    ON DELETE CASCADE
    ON UPDATE CASCADE
);
